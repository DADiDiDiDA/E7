{
    "interface_version": 2,
    "name": "MAA-E7",
    "description": "《第七史诗》自动化脚本 - 包含启动游戏、关闭公告栏、签到、刷体力、竞技场、商店购买、活跃度奖励等功能",
    "contact": "",
    "license": "MIT",
    "welcome": "欢迎使用第七史诗自动化助手",
    "version": "1.0.0",
    
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720
        }
    ],
    
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ]
        }
    ],
    
    "task": [
        {
            "name": "🚀 启动游戏",
            "entry": "启动游戏",
            "description": "最好使用设置里的启动功能而不是我"
        },
        {
            "name": "❌ 关闭公告栏",
            "entry": "检测公告栏",
            "description": "进入游戏前需关闭公告栏"
        },
        {
            "name": "🎮 进入游戏",
            "entry": "进入登陆界面",
            "description": "请放在❌关闭公告栏后面"
        },
        {
            "name": "📅 签到及辅助奖励",
            "entry": "有每日首次增益界面吗23",
            "description": "可能会比较慢，是正常的"
        },
        {
            "name": "⚔️ 刷体力",
            "entry": "进入战斗界面",
            "description": "可自定义选择要刷取的讨伐副本；只刷地狱级难度！！！！",
            "option": ["讨伐关卡选择"]
        },
        {
            "name": "🏟️ 竞技场10次",
            "entry": "进入竞技场选择",
            "description": "只刷人机竞技场，快速战斗次数和挑战次数任一不足时会退出"
        },
        {
            "name": "🛒 商店购买每日物品",
            "entry": "进入商店界面",
            "description": "只买友情点物品，友情点不够也没关系"
        },
        {
            "name": "🎁 领取活跃度奖励",
            "entry": "进入选择菜单前等待",
            "description": "只会领取活跃度100时的奖励，未到100不会领取"
        },
        {
            "name": "⚔️ 骑士团签到并请求资源",
            "entry": "点击主界面菜单选择",
            "description": "只会请求经验精灵"
        },
        {
            "name": "⏹️ 退出游戏",
            "entry": "退出游戏",
            "description": "其实没必要，直接使用设置里的功能即可"
        },
        {
            "name": "🔙 左上角返回主界面",
            "entry": "返回主界面两次",
            "description": "保底措施，以防止某些任务没有正常执行，无法返回主界面从而影响下一个任务执行"
        },
        {
            "name": "⚔️ 重复刷本",
            "entry": "检测自动战斗是否结束",
            "description": "进入自动战斗界面再开启（已经出现 自动战斗0/30 再开启）"
        },
        {
            "name": "🧪 TEST",
            "entry": "TEST开始",
            "description": "测试任务 - 执行后直接退出游戏"
        }
    ],
    
    "option": {
        "讨伐关卡选择": {
            "type": "select",
            "label": "讨伐关卡选择",
            "description": "选择要自动刷取的讨伐副本",
            "default_case": "双足飞龙",
            "cases": [
                {
                    "name": "双足飞龙",
                    "label": "双足飞龙",
                    "description": "暴击/命中/速度",
                    "pipeline_override": {
                        "开始讨伐关卡选择": {
                            "next": ["选择双足飞龙关卡"]
                        }
                    }
                },
                {
                    "name": "魔像",
                    "label": "魔像",
                    "description": "攻击/生命/防御/守护",
                    "pipeline_override": {
                        "开始讨伐关卡选择": {
                            "next": ["选择魔像关卡"]
                        }
                    }
                },
                {
                    "name": "报丧妖",
                    "label": "报丧妖",
                    "description": "抵抗/吸血/爆伤/反击",
                    "pipeline_override": {
                        "开始讨伐关卡选择": {
                            "next": ["选择报丧妖关卡"]
                        }
                    }
                },
                {
                    "name": "阿吉玛纳克",
                    "label": "阿吉玛纳克",
                    "description": "夹攻/免疫/愤怒",
                    "pipeline_override": {
                        "开始讨伐关卡选择": {
                            "next": ["选择讨伐阿吉玛纳克关卡"]
                        }
                    }
                },
                {
                    "name": "卡戴斯",
                    "label": "卡戴斯",
                    "description": "憎恨/伤口/穿透/激流",
                    "pipeline_override": {
                        "开始讨伐关卡选择": {
                            "next": ["选择讨伐卡戴斯关卡"]
                        }
                    }
                }
            ]
        }
    }
}